# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string — required for the Wishes feature.
# On Replit, provision a database and it will be set automatically.
DATABASE_URL=postgresql://user:password@host:5432/dreamwalk

# ─── Lyrics & Search ─────────────────────────────────────────────────────────
# Musixmatch API key — enables synced/richsync lyrics and song search.
# Without this, lyrics fall back to lyrics.ovh (plain text) and search
# falls back to iTunes Search API.
# https://developer.musixmatch.com/
MUSIXMATCH_KEY=your_musixmatch_api_key

# ─── Charts ──────────────────────────────────────────────────────────────────
# Songstats Enterprise API key — powers the global trending charts.
# Without this, charts fall back to the Apple Music RSS top-songs feed.
# https://songstats.com/for-developers
SONGSTATS_KEY=your_songstats_api_key

# ─── Mood Analysis ───────────────────────────────────────────────────────────
# Cyanite AI access token — provides audio feature analysis (energy, valence,
# danceability, tempo) used for automatic world selection.
# Without this, world selection falls back to a genre/title heuristic.
# https://cyanite.ai/
CYANITE_ACCESS_TOKEN=your_cyanite_access_token

# ─── Stem Separation ─────────────────────────────────────────────────────────
# LALAL.AI license key — separates vocals from instrumentals in "Any Song"
# mode so the 3D scene reacts to just the music bed.
# Without this, the raw preview audio is used directly.
# https://www.lalal.ai/api/
LALAL_KEY=your_lalal_license_key

# ─── Narration (Text-to-Speech) ──────────────────────────────────────────────
# ElevenLabs API key — generates the atmospheric whispered intro narration
# heard when entering a dream world.
# Without this, the narration step is silently skipped.
# https://elevenlabs.io/
ELEVEN_KEY=your_elevenlabs_api_key

# ─── Server (optional overrides) ─────────────────────────────────────────────
# PORT is set automatically by the Replit runtime — do not set manually.
# LOG_LEVEL controls API server verbosity: trace | debug | info | warn | error
LOG_LEVEL=info
